# Normalize line endings
#
# This file ensures Git normalizes line endings and forces LF for important text files
# so CI runners (Linux) do not choke on Windows CRLF shebangs.

# Let Git handle text files automatically
* text=auto

# Force LF for scripts, config and common source files
*.sh     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.kt     text eol=lf
*.java   text eol=lf
*.xml    text eol=lf
*.md     text eol=lf
